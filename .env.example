# Upstash Redis for rate limiting (shared across all endpnt APIs)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# API Keys (JSON array of valid API keys)
API_KEYS=["key1", "key2"]

# Demo keys for Pattern B demo auth (server-side only)
DEMO_API_KEY=demo_key_value